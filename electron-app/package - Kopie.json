{
  "name": "vibe-desktop",
  "version": "0.1.0",
  "description": "Vibe desktop app",
  "private": true,
  "main": "src/main.cjs",
  "author": "Vibe",
  "scripts": {
    "start": "electron .",
    "desktop": "electron .",
    "build": "electron-builder",
    "desktop:build": "electron-builder",
    "build:win": "electron-builder --win nsis",
    "desktop:build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage deb",
    "desktop:build:linux": "electron-builder --linux AppImage deb",
    "build:mac": "electron-builder --mac dmg zip",
    "desktop:build:mac": "electron-builder --mac dmg zip"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.vibe.desktop",
    "productName": "Vibe",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vibe"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.social-networking",
      "icon": "assets/icon.png"
    }
  }
}
